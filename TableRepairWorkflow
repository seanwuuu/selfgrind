        private bool ShouldApplySafetyPhaseEndTargetSpeedVerify()
        {
            return _checkpoint?.Request?.RunMode == TableRepairRunMode.Normal
                && !_inventerService.IsHandwareDemoPlatForm;
        }

        private bool IsSpindleAtTargetSpeed(SelfGrindConfig config)
        {
            if (_inventerService.IsHandwareDemoPlatForm || config == null)
            {
                return false;
            }

            if (_inventerService.FrequencyReached)
            {
                return true;
            }

            var targetHz = ResolveWheelRpm(config) * 0.04;
            var minHz = targetHz * (1 - SpindleTargetSpeedToleranceRatio);
            return _inventerService.CurrentFrequency >= minHz;
        }

        private bool IsTableAtTargetSpeed(SelfGrindConfig config)
        {
            if (config == null)
            {
                return false;
            }

            var tableIndex = (int)AxisType.Table;
            if (_controlCard.ServoDatas == null || _controlCard.ServoDatas.Count <= tableIndex)
            {
                return false;
            }

            var table = _controlCard.ServoDatas[tableIndex];
            if (!table.IsMoving)
            {
                return false;
            }

            var targetRpm = ResolveTableRpm(config);
            var tolerance = Math.Max(targetRpm * TableTargetSpeedToleranceRatio, TableTargetSpeedMinToleranceRpm);
            return Math.Abs(table.ActualVelocity - targetRpm) <= tolerance;
        }

        private static string BuildTargetSpeedVerifyFailureMessage(bool spindleOk, bool tableOk)
        {
            if (!spindleOk && !tableOk)
            {
                return "安全阶段结束：主轴与工作台均未达设定转速，已中止并回零。";
            }

            if (!spindleOk)
            {
                return "安全阶段结束：主轴未达设定转速，已中止并回零。";
            }

            return "安全阶段结束：工作台未达设定转速，已中止并回零。";
        }

        private async Task<bool> VerifySpindleAndTableAtTargetSpeedAtPhaseEndAsync(
            ITableRepairWorkflowProgress progress,
            string phaseLabel,
            CancellationToken cancellationToken)
        {
            if (!ShouldApplySafetyPhaseEndTargetSpeedVerify())
            {
                return true;
            }

            var config = _checkpoint?.Request?.Config;
            if (config == null)
            {
                return true;
            }

            var targetWheelRpm = ResolveWheelRpm(config);
            var targetTableRpm = ResolveTableRpm(config);
            const int checkIntervalMs = 100;
            var elapsed = 0;
            var spindleOk = false;
            var tableOk = false;

            while (elapsed <= InventerFrequencyReachedTimeoutMs)
            {
                cancellationToken.ThrowIfCancellationRequested();

                spindleOk = IsSpindleAtTargetSpeed(config);
                tableOk = IsTableAtTargetSpeed(config);
                if (spindleOk && tableOk)
                {
                    LogSpindleTableTelemetry($"{phaseLabel}-verify-passed");
                    Logs.LogInfo(
                        $"[SelfGrind] {phaseLabel} target-speed verify passed elapsed={elapsed}ms " +
                        $"targetSpindleRpm={targetWheelRpm:F0} targetTableRpm={targetTableRpm:F0}");
                    _pendingWorkflowErrorMessage = null;
                    return true;
                }

                if (elapsed >= InventerFrequencyReachedTimeoutMs)
                {
                    break;
                }

                await Task.Delay(checkIntervalMs, cancellationToken).ConfigureAwait(false);
                elapsed += checkIntervalMs;
            }

            LogSpindleTableTelemetry($"{phaseLabel}-verify-failed");
            Logs.LogWarning(
                $"[SelfGrind] {phaseLabel} target-speed verify failed elapsed={elapsed}ms " +
                $"spindleOk={spindleOk} tableOk={tableOk} targetSpindleRpm={targetWheelRpm:F0} targetTableRpm={targetTableRpm:F0}");

            _pendingWorkflowErrorMessage = BuildTargetSpeedVerifyFailureMessage(spindleOk, tableOk);
            if (_checkpoint != null)
            {
                _checkpoint.SpindleAndTableRunning = spindleOk && tableOk;
            }

            return false;
        }

        private bool ShouldEnforceOverloadLimits()
        {
            return !IsDebugMode();
        }

        private static bool IsSuspectOverloadReading(double pct)
        {
            return pct <= -0.5 || Math.Abs(pct) > SuspectOverloadReadingThreshold;
        }

        private void LogSuspectOverloadReadingIfNeeded(string context)
        {
            var wheel = GetWheelOverloadPercent();
            if (IsSuspectOverloadReading(wheel))
            {
                Logs.LogWarning($"[SelfGrind-Overload] suspect reading axis=Wheel value={wheel:F1} {context}");
            }

            var table = GetTableOverloadPercent();
            if (IsSuspectOverloadReading(table))
            {
                Logs.LogWarning($"[SelfGrind-Overload] suspect reading axis=Table value={table:F1} {context}");
            }
        }

        private void MaybeLogWheelHomeOverloadTelemetry(SelfGrindConfig config)
        {
            if (config == null)
            {
                return;
            }

            var wheelPct = GetWheelOverloadPercent();
            var tablePct = GetTableOverloadPercent();
            var wheelThreshold = config.WheelOverloadLimit > 0 ? config.WheelOverloadLimit * 0.8 : 0;
            var tableThreshold = config.TableOverloadLimit > 0 ? config.TableOverloadLimit * 0.8 : 0;
            var now = DateTime.UtcNow;
            var shouldLog = wheelPct > wheelThreshold
                || tablePct > tableThreshold
                || Math.Abs(tablePct) > tableThreshold
                || (now - _lastWheelHomeOverloadLogUtc).TotalMilliseconds >= WheelHomeOverloadLogIntervalMs;

            if (!shouldLog)
            {
                return;
            }

            _lastWheelHomeOverloadLogUtc = now;
            var pos = GetWheelPosition();
            LogSuspectOverloadReadingIfNeeded($"WheelHome tick pos={pos:F0}");
            Logs.LogInfo(
                $"[SelfGrind-Overload] WheelHome tick pos={pos:F0} wheel={wheelPct:F1}/{config.WheelOverloadLimit:F1} " +
                $"table={tablePct:F1}/{config.TableOverloadLimit:F1} spindleRunning={_checkpoint?.SpindleAndTableRunning ?? false}");
        }

        private bool TryGetOverloadExceeded(SelfGrindConfig config, out bool wheelExceeded, out bool tableExceeded)
        {
            wheelExceeded = IsWheelOverloadExceeded(config.WheelOverloadLimit);
            tableExceeded = IsTableOverloadExceeded(config.TableOverloadLimit);
            return wheelExceeded || tableExceeded;
        }

        private async Task ThrowIfOverloadExceededAsync(
            ITableRepairWorkflowProgress progress,
            CancellationToken cancellationToken)
        {
            if (_overloadHomingTriggered || !ShouldEnforceOverloadLimits())
            {
                return;
            }

            var config = _checkpoint?.Request?.Config;
            if (config == null || !TryGetOverloadExceeded(config, out var wheelExceeded, out var tableExceeded))
            {
                return;
            }

            var step = _checkpoint?.Step.ToString() ?? "unknown";
            var pos = GetWheelPosition();
            var wheelPct = GetWheelOverloadPercent();
            var tablePct = GetTableOverloadPercent();
            LogSuspectOverloadReadingIfNeeded($"check step={step} pos={pos:F0}");
            Logs.LogError(
                $"[SelfGrind-Overload] check step={step} pos={pos:F0} wheel={wheelPct:F1}/{config.WheelOverloadLimit:F1} we={wheelExceeded} " +
                $"table={tablePct:F1}/{config.TableOverloadLimit:F1} te={tableExceeded} spindleRunning={_checkpoint?.SpindleAndTableRunning ?? false}");

            await HandleOverloadExceededAsync(progress, wheelExceeded, tableExceeded)
                .ConfigureAwait(false);
            throw new OverloadLimitExceededException(wheelExceeded, tableExceeded);
        }

        private async Task HandleOverloadExceededAsync(
            ITableRepairWorkflowProgress progress,
            bool wheelExceeded,
            bool tableExceeded)
        {
            _overloadHomingTriggered = true;
            _overloadMidpointSpindleStopped = false;

            var spindleRunningBefore = _checkpoint?.SpindleAndTableRunning ?? false;
            var willRestartSpindle = _checkpoint != null && !spindleRunningBefore;
            var wheelBefore = GetWheelOverloadPercent();
            var tableBefore = GetTableOverloadPercent();
            var posBeforeStop = GetWheelPosition();
            Logs.LogError(
                $"[SelfGrind-Overload] snapshot beforeStop wheel={wheelBefore:F1} table={tableBefore:F1} " +
                $"spindleRunning={spindleRunningBefore} pos={posBeforeStop:F0} willRestartSpindle={willRestartSpindle}");

            await _controlCard.StopAxisAsync(AxisType.Wheel).ConfigureAwait(false);
            _wheelMove.Reset();

            var wheelAfter = GetWheelOverloadPercent();
            var tableAfter = GetTableOverloadPercent();
            Logs.LogError(
                $"[SelfGrind-Overload] snapshot afterStop wheel={wheelAfter:F1} table={tableAfter:F1} " +
                $"spindleRunning={_checkpoint?.SpindleAndTableRunning ?? false} pos={GetWheelPosition():F0}");

            var config = _checkpoint?.Request?.Config;
            var step = _checkpoint?.Step.ToString() ?? "unknown";
            var wheelPct = GetWheelOverloadPercent();
            var tablePct = GetTableOverloadPercent();
            var wheelLimit = config?.WheelOverloadLimit ?? 0;
            var tableLimit = config?.TableOverloadLimit ?? 0;
            var rapidMidpointPassed = _checkpoint?.RapidMidpointPassed ?? false;
            Logs.LogError(
                $"[SelfGrind-Overload] triggered step={step} wheelExceeded={wheelExceeded} wheel={wheelPct:F1}% limit={wheelLimit:F1}% " +
                $"tableExceeded={tableExceeded} table={tablePct:F1}% limit={tableLimit:F1}% rapidMidpointPassed={rapidMidpointPassed}");

            var overloadMsg = BuildOverloadMessage(wheelExceeded, tableExceeded);
            Logs.LogError($"[SelfGrind-Overload] {overloadMsg}");
            ReportWorkflowError(progress, overloadMsg);
            progress?.ReportOverloadAlert(wheelExceeded, tableExceeded);
            progress?.ReportPhase("回零");

            if (_checkpoint != null && !_checkpoint.SpindleAndTableRunning)
            {
                if (!_checkpoint.RapidMidpointPassed)
                {
                    Logs.LogInfo("[SelfGrind-Overload] pre-rapid-midpoint spindle start for overload homing.");
                }

                if (config != null
                    && await StartSpindleAndTableAsync(
                        config,
                        CancellationToken.None,
                        skipFrequencyWait: true).ConfigureAwait(false))
                {
                    _checkpoint.SpindleAndTableRunning = true;
                }
                else
                {
                    Logs.LogWarning("[SelfGrind-Overload] spindle/table start failed; continuing overload homing.");
                }
            }

            _overloadHomingStartUm = GetWheelPosition();
            Logs.LogInfo(
                $"[SelfGrind-Overload] homing start pos={_overloadHomingStartUm:F0} speed={OverloadHomingSpeedUmS:F0}um/s midpoint={_overloadHomingStartUm / 2.0:F0}");

            var homeOk = await _wheelMove.TickReturnToZeroUntilAsync(
                OverloadHomingSpeedUmS,
                () =>
                {
                    ThrowIfStopRequested();
                    return Task.CompletedTask;
                },
                ThrowIfTorqueAccident,
                async () =>
                {
                    await TryStopSpindleAndTableAtHomingMidpointAsync(
                        _overloadHomingStartUm,
                        GetWheelPosition(),
                        ref _overloadMidpointSpindleStopped,
                        "OverloadHoming50").ConfigureAwait(false);
                },
                CancellationToken.None).ConfigureAwait(false);

            var finalPos = GetWheelPosition();
            if (homeOk)
            {
                Logs.LogInfo(
                    $"[SelfGrind-Overload] homing complete finalPos={finalPos:F0} midpointStopped={_overloadMidpointSpindleStopped}");
            }
            else
            {
                Logs.LogError(
                    $"[SelfGrind-Overload] homing incomplete finalPos={finalPos:F0} midpointStopped={_overloadMidpointSpindleStopped}");
            }

            if (_checkpoint != null
                && _checkpoint.SpindleAndTableRunning
                && !_overloadMidpointSpindleStopped)
            {
                Logs.LogWarning(
                    $"[SelfGrind-Overload] homing midpoint spindle stop not reached startUm={_overloadHomingStartUm:F0} finalPos={finalPos:F0}; force-stopping at phase end.");
            }

            await EnsureSpindleStoppedAfterReturnPhaseAsync().ConfigureAwait(false);
            ScheduleCoolantOffAfterHomingAsync();
        }

        private static string BuildOverloadMessage(bool wheelExceeded, bool tableExceeded)
        {
            if (wheelExceeded && tableExceeded)
            {
                return "砂轮与工作台过载超限，已强制回零。";
            }

            if (wheelExceeded)
            {
                return "砂轮过载超限，已强制回零。";
            }

            return "工作台过载超限，已强制回零。";
        }

        private async Task TryStopSpindleAndTableAtHomingMidpointAsync(
            double homingStartUm,
            double currentPos,
            ref bool midpointStoppedFlag,
            string path)
        {
            if (_checkpoint == null || !_checkpoint.SpindleAndTableRunning || midpointStoppedFlag)
            {
                return;
            }

            var refPos = homingStartUm / 2.0;
            var tolerance = TableRepairWheelMoveController.HomePositionToleranceUm;
            if (currentPos <= refPos + tolerance)
            {
                await StopSpindleAndTableAsync().ConfigureAwait(false);
                midpointStoppedFlag = true;
                Logs.LogInfo(
                    $"[SelfGrind-SpinStop] stopped at homing midpoint path={path} pos={currentPos:F0} ref={refPos:F0} homingStartUm={homingStartUm:F0}");
            }
        }

        private void MaybeLogWheelHomeSpinStopTick(double homingStartUm, double currentPos, double midpointUm)
        {
            if (_wheelHomeMidpointStopped)
            {
                return;
            }

            var now = DateTime.UtcNow;
            var deltaFromLast = double.IsNaN(_lastSpinStopLoggedPos)
                ? double.MaxValue
                : Math.Abs(currentPos - _lastSpinStopLoggedPos);
            var throttleElapsed = (now - _lastSpinStopTickLogUtc).TotalMilliseconds;
            if (throttleElapsed < SpinStopLogThrottleMs && deltaFromLast < SpinStopLogPositionDeltaUm)
            {
                return;
            }

            _lastSpinStopTickLogUtc = now;
            _lastSpinStopLoggedPos = currentPos;
            var progress = homingStartUm != 0
                ? Math.Min(1, Math.Abs(homingStartUm - currentPos) / Math.Abs(homingStartUm))
                : 1;
            Logs.LogInfo(
                $"[SelfGrind-SpinStop] WheelHome tick pos={currentPos:F0} progress={progress:P0} midpointUm={midpointUm:F0} untilStop=true");
        }

        private sealed class OverloadLimitExceededException : Exception
        {
            public OverloadLimitExceededException(bool wheelExceeded, bool tableExceeded)
                : base(BuildOverloadMessage(wheelExceeded, tableExceeded))
            {
            }
        }

        private async Task EnsureCoolantOnAsync(CancellationToken cancellationToken)
        {
            if (!_controlCard.Initialized)
            {
                Logs.LogInfo("[SelfGrind] Coolant skipped (control card not initialized).");
                return;
            }

            if (_checkpoint == null || _checkpoint.CoolantEnabled)
            {
                return;
            }

            await ExtendCoolantValvesAsync(cancellationToken).ConfigureAwait(false);
            _checkpoint.CoolantEnabled = true;
            Logs.LogInfo("[SelfGrind] Coolant valves extended (surface, turntable).");
        }

        private async Task<bool> TryExecuteRapidMidpointActionsAsync(
            CancellationToken cancellationToken,
            bool reportSpindleFailure = true)
        {
            if (_checkpoint == null || _checkpoint.RapidMidpointPassed)
            {
                return true;
            }

            if (!IsRapidMidpointReached())
            {
                return true;
            }

            if (_rapidMidpointActionsInProgress)
            {
                return true;
            }

            _rapidMidpointActionsInProgress = true;
            try
            {
                await EnsureCoolantOnAsync(cancellationToken).ConfigureAwait(false);
                if (!await EnsureSpindleAndTableRunningAsync(cancellationToken, reportSpindleFailure)
                        .ConfigureAwait(false))
                {
                    return false;
                }

                _checkpoint.RapidMidpointPassed = true;
                Logs.LogInfo(
                    $"[SelfGrind] Rapid midpoint actions complete ref={_checkpoint.CoolantReferencePosition:F0}");
                return true;
            }
            finally
            {
                _rapidMidpointActionsInProgress = false;
            }
        }

        private bool IsRapidMidpointReached()
        {
            if (_checkpoint == null)
            {
                return false;
            }

            var current = GetWheelPosition();
            var progress = CalculateMovePhaseProgress(
                _checkpoint.MoveSegmentStartUm,
                _checkpoint.RapidPosition,
                current);
            var elapsedMs = (int)(DateTime.UtcNow - _rapidSegmentStartedUtc).TotalMilliseconds;

            if (!_coolantMidpointCheckLogged)
            {
                _coolantMidpointCheckLogged = true;
                Logs.LogInfo(
                    $"[SelfGrind] Rapid midpoint check: start={_checkpoint.MoveSegmentStartUm:F0} " +
                    $"target={_checkpoint.RapidPosition:F0} current={current:F0} progress={progress:P0} " +
                    $"elapsed={elapsedMs}ms half={_rapidCoolantHalfDelayMs}ms");
            }

            return progress >= 0.5 || elapsedMs >= _rapidCoolantHalfDelayMs;
        }

        private async Task TrackWheelPositionAndTryMidpointStopAsync()
        {
            var current = GetWheelPosition();
            if (!double.IsNaN(_lastWheelPositionUm))
            {
                await TryStopSpindleAndTableAtMidpointReturnAsync(_lastWheelPositionUm, current)
                    .ConfigureAwait(false);
            }

            _lastWheelPositionUm = current;
        }

        private async Task TryStopSpindleAndTableAtMidpointReturnAsync(double previousPos, double currentPos)
        {
            if (_checkpoint == null || !_checkpoint.RapidMidpointPassed || !_checkpoint.SpindleAndTableRunning)
            {
                return;
            }

            var refPos = _checkpoint.CoolantReferencePosition;
            var tolerance = TableRepairWheelMoveController.HomePositionToleranceUm;
            if (previousPos > refPos + tolerance && currentPos <= refPos + tolerance)
            {
                await StopSpindleAndTableAsync().ConfigureAwait(false);
                Logs.LogInfo(
                    $"[SelfGrind-SpinStop] stopped at rapid midpoint return path=GeoMidpoint " +
                    $"pos={currentPos:F0} ref={refPos:F0}");
            }
        }

        private async Task StopSpindleAndTableAsync([CallerMemberName] string caller = null)
        {
            if (_checkpoint == null)
            {
                return;
            }

            LogSpindleTelemetry("stop-before");
            Logs.LogInfo(
                $"[SelfGrind-SpinStop] StopSpindleAndTable caller={caller ?? "unknown"} " +
                $"step={_checkpoint.Step} pos={GetWheelPosition():F0}");

            try
            {
                await _controlCard.StopAxisAsync(AxisType.Table).ConfigureAwait(false);
                if (!await _inventerService.FreeStopAsync(false).ConfigureAwait(false))
                {
                    Logs.LogError("[SelfGrind] Spindle FreeStopAsync command failed.");
                }
            }
            catch (Exception ex)
            {
                Logs.LogWarning($"Self-Grind stop spindle/table warning: {ex.Message}");
            }

            _checkpoint.SpindleAndTableRunning = false;
        }

        private async Task EnsureSpindleStoppedAfterReturnPhaseAsync(
            string caller = null,
            bool? midpointStopped = null)
        {
            if (_checkpoint == null || !_checkpoint.SpindleAndTableRunning)
            {
                return;
            }

            if (midpointStopped == false)
            {
                Logs.LogWarning(
                    $"[SelfGrind-SpinStop] fallback force-stop at phase end caller={caller ?? "unknown"} " +
                    $"step={_checkpoint.Step} pos={GetWheelPosition():F0} midpointStopped=false");
            }

            await StopSpindleAndTableAsync(caller ?? nameof(EnsureSpindleStoppedAfterReturnPhaseAsync))
                .ConfigureAwait(false);
        }

        private bool ShouldResumeSpindleAndTable()
        {
            if (_checkpoint == null || !_checkpoint.RapidMidpointPassed || _checkpoint.SpindleAndTableRunning)
            {
                return false;
            }

            var tolerance = TableRepairWheelMoveController.HomePositionToleranceUm;
            var refPos = _checkpoint.CoolantReferencePosition;
            var currentPos = GetWheelPosition();

            switch (_checkpoint.Step)
            {
                case TableRepairWorkflowStep.Rapid:
                    return _checkpoint.CoolantEnabled;
                case TableRepairWorkflowStep.Safety:
                case TableRepairWorkflowStep.Grind:
                case TableRepairWorkflowStep.SparkOut:
                case TableRepairWorkflowStep.Escape:
                    return true;
                case TableRepairWorkflowStep.WheelHome:
                    return currentPos > refPos + tolerance;
                default:
                    return false;
            }
        }

        private async Task ExtendCoolantValvesAsync(CancellationToken cancellationToken)
        {
            await ExtendCoolantValveAsync(CylinderType.SurfaceCleaningValve_Sol, cancellationToken)
                .ConfigureAwait(false);
            await ExtendCoolantValveAsync(CylinderType.TurntableCleaningValve_Sol, cancellationToken)
                .ConfigureAwait(false);
        }

        private async Task ExtendCoolantValveAsync(CylinderType cylinderType, CancellationToken cancellationToken)
        {
            var cylinder = _cylinderManager.GetCylinder(cylinderType);
            if (cylinder == null)
            {
                var msg = $"冷却液阀 {cylinderType} 未注册，无法开启。";
                Logs.LogError($"[SelfGrind] {msg}");
                ReportWorkflowError(_workflowProgress, msg);
                throw new InvalidOperationException(msg);
            }

            if (!await cylinder.ExtendAsync(cancellationToken).ConfigureAwait(false))
            {
                var msg = $"冷却液阀 {cylinderType} 伸出失败。";
                Logs.LogError($"[SelfGrind] {msg}");
                ReportWorkflowError(_workflowProgress, msg);
                throw new InvalidOperationException(msg);
            }
        }

        private async Task StopMotionAndHomeAsync()
        {
            var entryPos = GetWheelPosition();
            var step = _checkpoint?.Step.ToString() ?? "unknown";
            Logs.LogInfo(
                $"[SelfGrind-Home] StopMotionAndHomeAsync started step={step} pos={entryPos:F3} stopRequested={_stopRequested}");
            var started = DateTime.UtcNow;
            _wheelMove.Reset();

            try
            {
                if (_checkpoint != null
                    && _checkpoint.RapidMidpointPassed
                    && _checkpoint.SpindleAndTableRunning)
                {
                    await HomeWheelWithMidpointSpindleStopAsync(CancellationToken.None).ConfigureAwait(false);
                }
                else
                {
                    await StopSpindleAndTableAsync().ConfigureAwait(false);
                    await _controlCard.StopAxisAsync(AxisType.Wheel).ConfigureAwait(false);
                    await _controlCard.MoveToZeroAsync(AxisType.Wheel).ConfigureAwait(false);
                }

                await EnsureSpindleStoppedAfterReturnPhaseAsync().ConfigureAwait(false);
                ScheduleCoolantOffAfterHomingAsync();
            }
            catch (Exception ex)
            {
                Logs.LogWarning($"Self-Grind stop and home warning: {ex.Message}");
                await StopSpindleAndTableAsync().ConfigureAwait(false);
            }

            Logs.LogInfo(
                $"[SelfGrind-Home] StopMotionAndHomeAsync completed step={step} finalPos={GetWheelPosition():F3} elapsedMs={(DateTime.UtcNow - started).TotalMilliseconds:F0}");
        }

        private async Task StopMotionAndHomeForDebugAsync()
        {
            _wheelMove.Reset();

            try
            {
                if (_checkpoint != null
                    && _checkpoint.RapidMidpointPassed
                    && _checkpoint.SpindleAndTableRunning)
                {
                    await HomeWheelWithMidpointSpindleStopAsync(CancellationToken.None).ConfigureAwait(false);
                }
                else
                {
                    await StopSpindleAndTableAsync().ConfigureAwait(false);
                    await _controlCard.StopAxisAsync(AxisType.Wheel).ConfigureAwait(false);
                    await _controlCard.MoveToZeroAsync(AxisType.Wheel).ConfigureAwait(false);
                }

                await EnsureSpindleStoppedAfterReturnPhaseAsync().ConfigureAwait(false);
                ScheduleCoolantOffAfterHomingAsync();
            }
            catch (Exception ex)
            {
                Logs.LogWarning($"Self-Grind debug stop and home warning: {ex.Message}");
                await StopSpindleAndTableAsync().ConfigureAwait(false);
            }
        }

        private async Task HomeWheelWithMidpointSpindleStopAsync(CancellationToken cancellationToken)
        {
            await _controlCard.StopAxisAsync(AxisType.Wheel).ConfigureAwait(false);
            _wheelMove.Reset();
            var homingStartUm = GetWheelPosition();
            _lastWheelPositionUm = homingStartUm;
            Logs.LogInfo(
                $"[SelfGrind-SpinStop] stop-homing enter path=GeoMidpoint homingStartUm={homingStartUm:F0} " +
                $"coolantRef={_checkpoint?.CoolantReferencePosition:F0}");

            await _wheelMove.TickHomeUntilAsync(
                () => Task.CompletedTask,
                () => { },
                async () => await TrackWheelPositionAndTryMidpointStopAsync().ConfigureAwait(false),
                cancellationToken).ConfigureAwait(false);
        }

        private Task ScheduleCoolantOffAfterHomingAsync()
        {
            if (_checkpoint == null || !_checkpoint.CoolantEnabled)
            {
                return Task.CompletedTask;
            }

            _coolantOffCts?.Cancel();
            _coolantOffCts = new CancellationTokenSource();
            var token = _coolantOffCts.Token;
            _coolantOffTask = CoolantOffAfterHomingAsync(token);
            return _coolantOffTask;
        }

        private async Task CoolantOffAfterHomingAsync(CancellationToken token)
        {
            try
            {
                await Task.Delay(CoolantOffDelayAfterHomingMs, token).ConfigureAwait(false);
                if (!await RetractCoolantValvesAsync().ConfigureAwait(false))
                {
                    Logs.LogWarning("[SelfGrind] Coolant valves retract incomplete after homing delay.");
                    return;
                }

                if (_checkpoint != null)
                {
                    _checkpoint.CoolantEnabled = false;
                }

                Logs.LogInfo("[SelfGrind] Coolant valves retracted after homing delay.");
            }
            catch (OperationCanceledException)
            {
            }
            catch (Exception ex)
            {
                Logs.LogWarning($"Self-Grind coolant off warning: {ex.Message}");
            }
        }

        private async Task<bool> RetractCoolantValvesAsync()
        {
            if (!_controlCard.Initialized)
            {
                Logs.LogWarning("[SelfGrind] Coolant retract skipped (control card not initialized).");
                return false;
            }

            var surfaceOk = await RetractCoolantValveAsync(CylinderType.SurfaceCleaningValve_Sol)
                .ConfigureAwait(false);
            var turntableOk = await RetractCoolantValveAsync(CylinderType.TurntableCleaningValve_Sol)
                .ConfigureAwait(false);
            return surfaceOk && turntableOk;
        }

        private async Task<bool> RetractCoolantValveAsync(CylinderType cylinderType)
        {
            var cylinder = _cylinderManager.GetCylinder(cylinderType);
            if (cylinder == null)
            {
                var msg = $"冷却液阀 {cylinderType} 未注册，无法关闭。";
                Logs.LogError($"[SelfGrind] {msg}");
                ReportWorkflowError(_workflowProgress, msg);
                return false;
            }

            if (!await cylinder.RetractAsync(CancellationToken.None).ConfigureAwait(false))
            {
                var msg = $"冷却液阀 {cylinderType} 缩回失败。";
                Logs.LogError($"[SelfGrind] {msg}");
                ReportWorkflowError(_workflowProgress, msg);
                return false;
            }

            return true;
        }

        private bool IsDebugMode()
        {
            return _checkpoint?.Request?.RunMode == TableRepairRunMode.Debug;
        }

        private bool ShouldEnforceRuntimeInterlocks()
        {
            return SelfGrindRuntimeInterlocksEnabled && !IsDebugMode();
        }

        private static bool IsDebugRequest(TableRepairRequest request)
        {
            return request?.RunMode == TableRepairRunMode.Debug;
        }

        private void ReportWorkflowError(ITableRepairWorkflowProgress progress, string message)
        {
            if (string.IsNullOrWhiteSpace(message))
            {
                return;
            }

            Logs.LogError($"[SelfGrind] {message}");
            progress?.ReportWorkflowError(message);
        }

        private void LogDebugInfo(string message)
        {
            if (IsDebugMode())
            {
                Logs.LogInfo($"[SelfGrind-Debug] {message}");
            }
        }

        private void TryApplyDebugMoveOverride(ref double targetUm, ref double speedUmS)
        {
            if (!IsDebugMode() || !_debugOverrideActive || _debugTargetUm <= 0 || _debugSpeedUmS <= 0)
            {
                return;
            }

            targetUm = _debugTargetUm;
            speedUmS = _debugSpeedUmS;
            ClearDebugOverrides();
        }

        private void ClearDebugOverrides()
        {
            _debugOverrideActive = false;
            _debugTargetUm = 0;
            _debugSpeedUmS = 0;
            _debugSparkOutSecondsOverride = 0;
        }

        private void ReportPhaseProgressForDebug(
            ITableRepairWorkflowProgress progress,
            SelfGrindPhaseWeights weights,
            TableRepairWorkflowStep step,
            double phaseProgress01,
            double processProgress,
            double targetUm,
            double segmentStartUm)
        {
            if (IsDebugMode() && _debugProgress != null)
            {
                _debugProgress.ReportDebugPhaseProgress(
                    step,
                    Math.Min(100, Math.Max(0, phaseProgress01 * 100)),
                    targetUm,
                    segmentStartUm);
                return;
