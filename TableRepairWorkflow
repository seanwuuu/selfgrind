            ReportWeightedProgress(progress, weights, step, phaseProgress01, processProgress);
        }

        private async Task RunTelemetryLoopAsync(ITableRepairWorkflowProgress progress, CancellationToken cancellationToken)
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                try
                {
                    progress?.ReportTelemetry(
                        GetWheelPosition(),
                        GetWheelRpm(),
                        GetTableRpm(),
                        GetWheelOverloadPercent(),
                        GetTableOverloadPercent());

                    await Task.Delay(200, cancellationToken).ConfigureAwait(false);
                }
                catch (OperationCanceledException)
                {
                    break;
                }
            }
        }

        private async Task<bool> WaitForConditionAsync(
            Func<bool> condition,
            int timeoutMs,
            string timeoutErrorMsg,
            CancellationToken cancellationToken)
        {
            var elapsed = 0;
            const int checkInterval = 200;

            while (elapsed < timeoutMs && !condition())
            {
                await Task.Delay(checkInterval, cancellationToken).ConfigureAwait(false);
                elapsed += checkInterval;
            }

            if (!condition())
            {
                Logs.LogError(timeoutErrorMsg);
                return false;
            }

            return true;
        }

        private void OnTorqueAccidentExceeded(double torque)
        {
            lock (_torqueLock)
            {
                _torqueAccidentTriggered = true;
            }

            Logs.LogWarning($"Self-Grind torque accident exceeded ({torque}%).");
        }

        private void ThrowIfTorqueAccident()
        {
            if (!ShouldEnforceRuntimeInterlocks())
            {
                return;
            }

            lock (_torqueLock)
            {
                if (_torqueAccidentTriggered)
                {
                    throw new InvalidOperationException("Torque accident threshold exceeded.");
                }
            }
        }

        private double GetWheelPosition()
        {
            return _controlCard.GetActualPosition((ushort)AxisType.Wheel);
        }

        private double GetWheelRpm()
        {
            return _inventerService.CurrentFrequency / 0.04;
        }

        private double GetTableRpm()
        {
            if (_controlCard.ServoDatas.Count <= (int)AxisType.Table)
            {
                return 0;
            }

            return _controlCard.ServoDatas[(int)AxisType.Table].ActualVelocity;
        }

        private double GetWheelOverloadPercent()
        {
            return _inventerService.OutputTorque;
        }

        private double GetTableOverloadPercent()
        {
            if (_controlCard.ServoDatas.Count <= (int)AxisType.Table)
            {
                return 0;
            }

            return _controlCard.ServoDatas[(int)AxisType.Table].ActualTorque;
        }

        private bool IsWheelOverloadExceeded(double limit)
        {
            if (limit <= 0)
            {
                return false;
            }

            return GetWheelOverloadPercent() > limit;
        }

        private bool IsTableOverloadExceeded(double limit)
        {
            if (limit <= 0)
            {
                return false;
            }

            return GetTableOverloadPercent() > limit;
        }

