        public async Task<TableRepairOutcome> RunAsync(
            TableRepairRequest request,
            ITableRepairWorkflowProgress progress,
            CancellationToken cancellationToken)
        {
            if (request == null || request.Config == null)
            {
                ReportWorkflowError(progress, "请求或配置为空，无法启动。");
                return TableRepairOutcome.Failed;
            }

            if (!ValidatePreconditions(request, out var errorMessage))
            {
                ReportWorkflowError(progress, errorMessage ?? "启动前检查失败。");
                progress?.ReportPhase("失败");
                return TableRepairOutcome.Failed;
            }

            lock (_controlLock)
            {
                if (IsActive)
                {
                    var busyMsg = IsDebugRequest(request)
                        ? "一键修台流程仍在运行，请等待结束或先点「停机」。"
                        : "一键修台流程正在运行。";
                    ReportWorkflowError(progress, busyMsg);
                    return TableRepairOutcome.Failed;
                }

                IsActive = true;
                IsPaused = false;
                _pauseRequested = false;
                _stopRequested = false;
            }

            _workflowProgress = progress;
            progress?.ClearOverloadAlert();
            _torqueAccidentTriggered = false;
            _overloadHomingTriggered = false;
            _overloadMidpointSpindleStopped = false;
            _wheelHomeMidpointStopped = false;
            _lastWheelHomeOverloadLogUtc = DateTime.MinValue;
            _lastSpinStopTickLogUtc = DateTime.MinValue;
            _lastSpinStopLoggedPos = double.NaN;
            _fastForwardRequested = false;
            _debugStopRequested = false;
            _pendingWorkflowErrorMessage = null;
            _debugProgress = progress as IDebugTableRepairWorkflowProgress;
            _coolantOffCts?.Cancel();
            if (_coolantOffTask != null)
            {
                try
                {
                    await _coolantOffTask.ConfigureAwait(false);
                }
                catch (OperationCanceledException)
                {
                }
                catch (Exception ex)
                {
                    Logs.LogWarning($"Self-Grind pending coolant off cleanup warning: {ex.Message}");
                }
            }

            _coolantOffTask = null;
            _coolantOffCts = null;
            _inventerService.TorqueAccidentExceeded += OnTorqueAccidentExceeded;

            var weights = request.PhaseWeights ?? new SelfGrindPhaseWeights();
            var telemetryCts = CancellationTokenSource.CreateLinkedTokenSource(cancellationToken);
            var telemetryTask = RunTelemetryLoopAsync(progress, telemetryCts.Token);
            var stopHandled = false;

            try
            {
                LogDebugInfo($"RunAsync started RunMode={request.RunMode}");
                InitializeCheckpoint(request);
                progress?.ReportStartPosition(_checkpoint.RecordedStartPosition);
                progress?.ReportPhase("准备");
                await AwaitRunGateAsync(cancellationToken).ConfigureAwait(false);

                while (_checkpoint.Step != TableRepairWorkflowStep.Done)
                {
                    cancellationToken.ThrowIfCancellationRequested();
                    ThrowIfStopRequested();
                    await AwaitRunGateAsync(cancellationToken).ConfigureAwait(false);

                    LogDebugInfo($"Executing step={_checkpoint.Step}");

                    switch (_checkpoint.Step)
                    {
                        case TableRepairWorkflowStep.Rapid:
                            progress?.ReportPhase("快进");
                            if (!await ExecuteRapidPhaseAsync(progress, weights, cancellationToken).ConfigureAwait(false))
                            {
                                return await HandleFailureAsync(progress).ConfigureAwait(false);
                            }

                            await CompletePhaseAndMaybeAutoPauseAsync(TableRepairWorkflowStep.Rapid, weights, cancellationToken)
                                .ConfigureAwait(false);
                            break;

                        case TableRepairWorkflowStep.Safety:
                            progress?.ReportPhase("安全");
                            if (!await ExecuteSafetyPhaseAsync(progress, weights, cancellationToken).ConfigureAwait(false))
                            {
                                return await HandleFailureAsync(progress).ConfigureAwait(false);
                            }

                            await CompletePhaseAndMaybeAutoPauseAsync(TableRepairWorkflowStep.Safety, weights, cancellationToken)
                                .ConfigureAwait(false);
                            break;

                        case TableRepairWorkflowStep.Grind:
                            progress?.ReportPhase("切削");
                            if (!await ExecuteGrindPhaseAsync(progress, weights, cancellationToken).ConfigureAwait(false))
                            {
                                return await HandleFailureAsync(progress).ConfigureAwait(false);
                            }

                            await CompletePhaseAndMaybeAutoPauseAsync(TableRepairWorkflowStep.Grind, weights, cancellationToken)
                                .ConfigureAwait(false);
                            break;

                        case TableRepairWorkflowStep.SparkOut:
                            progress?.ReportPhase("Spark Out");
                            if (!await ExecuteSparkOutPhaseAsync(progress, weights, cancellationToken).ConfigureAwait(false))
                            {
                                return await HandleFailureAsync(progress).ConfigureAwait(false);
                            }

                            await CompletePhaseAndMaybeAutoPauseAsync(TableRepairWorkflowStep.SparkOut, weights, cancellationToken)
                                .ConfigureAwait(false);
                            break;

                        case TableRepairWorkflowStep.Escape:
                            progress?.ReportPhase("Escape");
                            if (!await ExecuteEscapePhaseAsync(progress, weights, cancellationToken).ConfigureAwait(false))
                            {
                                return await HandleFailureAsync(progress).ConfigureAwait(false);
                            }

                            await CompletePhaseAndMaybeAutoPauseAsync(TableRepairWorkflowStep.Escape, weights, cancellationToken)
                                .ConfigureAwait(false);
                            break;

                        case TableRepairWorkflowStep.WheelHome:
                            if (IsDebugMode())
                            {
                                var debugEndUm = GetWheelPosition();
                                await EnsureSpindleStoppedAfterReturnPhaseAsync().ConfigureAwait(false);
                                progress?.ReportEndPosition(debugEndUm);
                                progress?.ReportProgress(100, 100);
                                progress?.ReportPhase("完成");
                                Logs.LogInfo(
                                    $"Self-Grind debug completed. Start={_checkpoint.RecordedStartPosition:F3}, End={debugEndUm:F3}");
                                ScheduleCoolantOffAfterHomingAsync();
                                return TableRepairOutcome.Success;
                            }

                            progress?.ReportPhase("回零");
                            if (!await ExecuteWheelHomePhaseAsync(progress, weights, cancellationToken).ConfigureAwait(false))
                            {
                                return await HandleFailureAsync(progress).ConfigureAwait(false);
                            }

                            CompletePhase(TableRepairWorkflowStep.WheelHome, weights);
                            var endPosition = GetWheelPosition();
                            progress?.ReportEndPosition(endPosition);
                            progress?.ReportProgress(100, 100);
                            progress?.ReportPhase("完成");
                            Logs.LogInfo(
                                $"Self-Grind completed. Start={_checkpoint.RecordedStartPosition:F3}, End={endPosition:F3}");
                            return TableRepairOutcome.Success;

                        default:
                            _checkpoint.Step = TableRepairWorkflowStep.Rapid;
                            break;
                    }
                }

                return TableRepairOutcome.Success;
            }
            catch (OperationCanceledException)
            {
                if (_stopRequested)
                {
                    stopHandled = true;
                    if (_overloadHomingTriggered)
                    {
                        Logs.LogInfo(
                            $"[SelfGrind-Overload] user stop during overload homing; skip StopMotionAndHomeAsync pos={GetWheelPosition():F3}");
                    }
                    else if (IsDebugMode() && _debugStopRequested)
                    {
                        await StopMotionAndHomeForDebugAsync().ConfigureAwait(false);
                    }
                    else
                    {
                        await StopMotionAndHomeAsync().ConfigureAwait(false);
                    }

                    progress?.ReportEndPosition(GetWheelPosition());
                    progress?.ReportPhase("Idle");
                    Logs.LogInfo("Self-Grind workflow stopped by user.");
                    return TableRepairOutcome.Cancelled;
                }

                progress?.ReportPhase("Idle");
                Logs.LogInfo("Self-Grind workflow cancelled.");
                return TableRepairOutcome.Cancelled;
            }
            catch (OverloadLimitExceededException)
            {
                stopHandled = true;
                Logs.LogInfo(
                    $"[SelfGrind-Overload] workflow failed after overload handling finalPos={GetWheelPosition():F3}");
                progress?.ReportPhase("失败");
                progress?.ReportEndPosition(GetWheelPosition());
                return TableRepairOutcome.Failed;
            }
            catch (Exception ex)
            {
                stopHandled = true;
                var failMsg = $"流程异常（Step={_checkpoint?.Step}）: {ex.Message}";
                Logs.LogError($"Self-Grind workflow failed: {ex.Message}");
                ReportWorkflowError(progress, failMsg);
                progress?.ReportPhase("失败");
                await StopMotionAndHomeAsync().ConfigureAwait(false);
                progress?.ReportEndPosition(GetWheelPosition());
                return TableRepairOutcome.Failed;
            }
            finally
            {
                _workflowProgress = null;
                _inventerService.TorqueAccidentExceeded -= OnTorqueAccidentExceeded;
                telemetryCts.Cancel();
                try
                {
                    await telemetryTask.ConfigureAwait(false);
                }
                catch (OperationCanceledException)
                {
                }

                if (!stopHandled && _stopRequested && !_overloadHomingTriggered)
                {
                    if (IsDebugMode() && _debugStopRequested)
                    {
                        await StopMotionAndHomeForDebugAsync().ConfigureAwait(false);
                    }
                    else
                    {
                        await StopMotionAndHomeAsync().ConfigureAwait(false);
                    }
                }
                else if (!stopHandled && _stopRequested && _overloadHomingTriggered)
                {
                    Logs.LogInfo(
                        $"[SelfGrind-Overload] finally: skip StopMotionAndHomeAsync (overload homing already handled) pos={GetWheelPosition():F3}");
                }

                if (_coolantOffTask != null)
                {
                    try
                    {
                        await _coolantOffTask.ConfigureAwait(false);
                    }
                    catch (Exception ex)
                    {
                        Logs.LogWarning($"Self-Grind coolant off await warning: {ex.Message}");
                    }
                }

                _coolantOffTask = null;
                _coolantOffCts = null;

                Logs.LogInfo("[SelfGrind] RunAsync finally: setting IsActive=false");
                lock (_controlLock)
                {
                    IsActive = false;
                    IsPaused = false;
                    _pauseRequested = false;
                    _stopRequested = false;
                    _fastForwardRequested = false;
                    _debugStopRequested = false;
                }

                Logs.LogInfo("[SelfGrind] RunAsync finally: IsActive=false");
            }
        }

        public async Task RequestPauseAsync()
        {
            lock (_controlLock)
            {
                if (!IsActive || IsPaused)
                {
                    return;
                }

                _pauseRequested = true;
            }

            await EnterPauseAsync().ConfigureAwait(false);
        }

        public Task RequestStopAsync()
        {
            lock (_controlLock)
            {
                _stopRequested = true;
                _pauseRequested = false;
            }

            Logs.LogInfo("[SelfGrind] RequestStopAsync: _stopRequested set");
            return Task.CompletedTask;
        }

        public Task RequestDebugStopAsync()
        {
            lock (_controlLock)
            {
                _debugStopRequested = true;
                _stopRequested = true;
                _pauseRequested = false;
                _fastForwardRequested = false;
            }

            return Task.CompletedTask;
        }

        public async Task RequestFastForwardAsync()
        {
            lock (_controlLock)
            {
                if (!IsActive || IsPaused)
                {
                    return;
                }

                _fastForwardRequested = true;
            }

            _wheelMove.Reset();
            try
            {
                await _controlCard.StopAxisAsync(AxisType.Wheel).ConfigureAwait(false);
            }
            catch (Exception ex)
            {
                Logs.LogWarning($"Self-Grind fast-forward stop warning: {ex.Message}");
            }

            if (_checkpoint?.Step == TableRepairWorkflowStep.Rapid
                && !_checkpoint.RapidMidpointPassed
                && IsRapidMidpointReached())
            {
                await TryExecuteRapidMidpointActionsAsync(CancellationToken.None, reportSpindleFailure: false)
                    .ConfigureAwait(false);
            }
        }

