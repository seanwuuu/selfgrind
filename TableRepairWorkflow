        {
            return config.RapidMoveSpeed > 0 ? config.RapidMoveSpeed : DefaultRapidMoveSpeed;
        }

        private static double ResolveSafetyGapSpeed(SelfGrindConfig config)
        {
            return config.SafetyGapSpeed > 0 ? config.SafetyGapSpeed : DefaultSafetyGapSpeed;
        }

        private static double ResolveRapidApproachOffset(SelfGrindConfig config)
