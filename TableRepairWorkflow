        public void ResumeWithConfig(SelfGrindConfig config)
        {
            if (config == null || _checkpoint?.Request == null)
            {
                var msg = _checkpoint?.Request == null
                    ? "无法恢复：流程检查点不存在，请关闭调试界面后重新打开。"
                    : "无法恢复：配置为空。";
                ReportWorkflowError(_workflowProgress, msg);
                Logs.LogError($"[SelfGrind-Debug] ResumeWithConfig failed: {msg}");
                return;
            }

            _checkpoint.Request.Config = config;
            lock (_controlLock)
            {
                _pauseRequested = false;
                IsPaused = false;
            }

            LogDebugInfo($"ResumeWithConfig step={_checkpoint.Step} pauseRequested cleared");
        }

        private void InitializeCheckpoint(TableRepairRequest request)
        {
            var buffer = ResolveSafetyEndBuffer(request.Config);
            var rapidApproachOffset = ResolveRapidApproachOffset(request.Config);
            var recordedStart = GetWheelPosition();
            var grindAmount = request.GrindAmount > 0 ? request.GrindAmount : 100;
            double safetyPosition;
            double grindTargetPosition;

            if (request.RunMode == TableRepairRunMode.Debug)
            {
                if (request.B >= request.A)
                {
                    safetyPosition = request.A - rapidApproachOffset;
                    grindTargetPosition = safetyPosition + grindAmount;
                    LogDebugInfo(
                        $"Debug: B>=A, adjusted Safety/D to {safetyPosition:F0} (A={request.A:F0})");
                }
                else
                {
                    safetyPosition = request.B - buffer;
                    grindTargetPosition = request.B + grindAmount;
                }

                var rapidPosition = safetyPosition - rapidApproachOffset;
                if (recordedStart >= rapidPosition)
                {
                    rapidPosition = recordedStart + rapidApproachOffset;
                    LogDebugInfo(
                        $"Debug: Z too high for default Rapid end, adjusted Rapid target to {rapidPosition:F0}");
                }

                _checkpoint = new TableRepairSessionCheckpoint
                {
                    Step = TableRepairWorkflowStep.Rapid,
                    Request = request,
                    RecordedStartPosition = recordedStart,
                    SafetyPosition = safetyPosition,
                    RapidPosition = rapidPosition,
                    GrindTargetPosition = grindTargetPosition,
                    CoolantReferencePosition = (recordedStart + rapidPosition) / 2,
                    SparkOutElapsedSeconds = 0,
                    CompletedWeightRatio = 0,
                    SpindleAndTableRunning = false,
                    CoolantEnabled = false,
                    RapidMidpointPassed = false
                };
                LogCheckpointPositions(request, recordedStart, buffer, rapidApproachOffset, rapidPosition, safetyPosition);
                return;
            }

            safetyPosition = request.B - buffer;
            var normalRapidPosition = safetyPosition - rapidApproachOffset;
            grindTargetPosition = request.B + request.GrindAmount;

            _checkpoint = new TableRepairSessionCheckpoint
            {
                Step = TableRepairWorkflowStep.Rapid,
                Request = request,
                RecordedStartPosition = recordedStart,
                SafetyPosition = safetyPosition,
                RapidPosition = normalRapidPosition,
                GrindTargetPosition = grindTargetPosition,
                CoolantReferencePosition = (recordedStart + normalRapidPosition) / 2,
                SparkOutElapsedSeconds = 0,
                CompletedWeightRatio = 0,
                SpindleAndTableRunning = false,
                CoolantEnabled = false,
                RapidMidpointPassed = false
            };
            LogCheckpointPositions(request, recordedStart, buffer, rapidApproachOffset, normalRapidPosition, safetyPosition);
        }

        private static void LogCheckpointPositions(
            TableRepairRequest request,
            double recordedStart,
            double buffer,
            double rapidApproachOffset,
            double rapidPosition,
            double safetyPosition)
        {
            Logs.LogInfo(
                $"[SelfGrind] Checkpoint A={request.A:F3} B={request.B:F3} buffer={buffer:F0} offset={rapidApproachOffset:F0} " +
                $"startZ={recordedStart:F3} C={rapidPosition:F3} D={safetyPosition:F3} grindEnd={request.B + request.GrindAmount:F3}");
        }

        private void CompletePhase(TableRepairWorkflowStep step, SelfGrindPhaseWeights weights)
        {
            var total = weights.Total;
            if (total <= 0)
            {
                total = 100;
            }

            _checkpoint.CompletedWeightRatio += weights.WeightFor(step) / total;
            _checkpoint.Step = step + 1;
        }

        private async Task CompletePhaseAndMaybeAutoPauseAsync(
            TableRepairWorkflowStep step,
            SelfGrindPhaseWeights weights,
            CancellationToken cancellationToken)
        {
            CompletePhase(step, weights);

            if (IsDebugMode())
            {
                _fastForwardRequested = false;

                lock (_controlLock)
                {
                    if (!IsActive || IsPaused)
                    {
                        return;
                    }

                    _pauseRequested = true;
                }

                LogDebugInfo($"Phase {step} completed, entering auto-pause");
                await EnterPauseAsync().ConfigureAwait(false);
                _debugProgress?.ReportPhaseCompleted(step);
                return;
            }

            if (_checkpoint.Request.RunMode == TableRepairRunMode.StepByStep)
            {
                lock (_controlLock)
                {
                    if (!IsActive || IsPaused)
                    {
                        return;
                    }

                    _pauseRequested = true;
                }

                await EnterPauseAsync().ConfigureAwait(false);
            }
        }

        private async Task<bool> ExecuteRapidPhaseAsync(
            ITableRepairWorkflowProgress progress,
            SelfGrindPhaseWeights weights,
            CancellationToken cancellationToken)
        {
            _checkpoint.MoveSegmentStartUm = GetWheelPosition();
            _coolantMidpointCheckLogged = false;
            var speed = ResolveRapidMoveSpeed(_checkpoint.Request.Config);
            var target = _checkpoint.RapidPosition;
            TryApplyDebugMoveOverride(ref target, ref speed);
            var segmentUm = Math.Abs(target - _checkpoint.MoveSegmentStartUm);
            var speedUmS = Math.Max(speed, 1);
            _rapidCoolantHalfDelayMs = (int)Math.Ceiling(segmentUm / speedUmS / 2.0 * 1000.0);
            _rapidSegmentStartedUtc = DateTime.UtcNow;
            Logs.LogInfo(
                $"[SelfGrind] Rapid coolant timing: segment={segmentUm:F0}um speed={speedUmS:F0}um/s halfDelay={_rapidCoolantHalfDelayMs}ms");
            LogDebugInfo($"ExecuteRapid start={_checkpoint.MoveSegmentStartUm:F0} target={target:F0} speed={speed:F0}");

            if (!await _wheelMove.TickMoveUntilAsync(
                target,
                speed,
                () => AwaitRunGateAsync(cancellationToken),
                ThrowIfTorqueAccident,
                async () =>
                {
                    await ThrowIfOverloadExceededAsync(progress, cancellationToken).ConfigureAwait(false);

                    if (!await TryExecuteRapidMidpointActionsAsync(cancellationToken).ConfigureAwait(false))
                    {
                        throw new InvalidOperationException("Rapid midpoint actions failed.");
                    }

                    var phaseProgress = CalculateMovePhaseProgress(
                        _checkpoint.MoveSegmentStartUm,
                        target,
                        GetWheelPosition());
                    ReportPhaseProgressForDebug(
                        progress,
                        weights,
                        TableRepairWorkflowStep.Rapid,
                        phaseProgress,
                        0,
                        target,
                        _checkpoint.MoveSegmentStartUm);
                },
                cancellationToken,
                TableRepairWheelMoveController.RapidPhaseToleranceUm,
                _checkpoint.MoveSegmentStartUm,
                allowDirectionalOvershoot: true,
                enableStallDetection: true,
                shouldAbortEarly: () => _fastForwardRequested).ConfigureAwait(false))
            {
                return false;
            }

            Logs.LogInfo("[SelfGrind] Rapid segment complete; ensuring coolant and spindle/table are on.");
            await EnsureCoolantOnAsync(cancellationToken).ConfigureAwait(false);
            if (!await EnsureSpindleAndTableRunningAsync(cancellationToken).ConfigureAwait(false))
            {
                return false;
            }

            _checkpoint.RapidMidpointPassed = true;

            ReportPhaseProgressForDebug(
                progress,
                weights,
                TableRepairWorkflowStep.Rapid,
                1,
                0,
                target,
                _checkpoint.MoveSegmentStartUm);
            return true;
        }

        private async Task<bool> ExecuteSafetyPhaseAsync(
            ITableRepairWorkflowProgress progress,
            SelfGrindPhaseWeights weights,
            CancellationToken cancellationToken)
        {
            var config = _checkpoint.Request.Config;

            _checkpoint.MoveSegmentStartUm = GetWheelPosition();
            var target = _checkpoint.SafetyPosition;
            var speed = ResolveSafetyGapSpeed(config);
            TryApplyDebugMoveOverride(ref target, ref speed);
            LogDebugInfo($"ExecuteSafety start={_checkpoint.MoveSegmentStartUm:F0} target={target:F0} speed={speed:F0}");

            if (!await _wheelMove.TickMoveUntilAsync(
                target,
                speed,
                () => AwaitRunGateAsync(cancellationToken),
                ThrowIfTorqueAccident,
                async () =>
                {
                    await ThrowIfOverloadExceededAsync(progress, cancellationToken).ConfigureAwait(false);

                    var phaseProgress = CalculateMovePhaseProgress(
                        _checkpoint.MoveSegmentStartUm,
                        target,
                        GetWheelPosition());
                    ReportPhaseProgressForDebug(
                        progress,
                        weights,
                        TableRepairWorkflowStep.Safety,
                        phaseProgress,
                        0,
                        target,
                        _checkpoint.MoveSegmentStartUm);
                },
                cancellationToken,
                TableRepairWheelMoveController.SafetyPhaseToleranceUm,
                enableStallDetection: true,
                shouldAbortEarly: () => _fastForwardRequested).ConfigureAwait(false))
            {
                return false;
            }

            ReportPhaseProgressForDebug(
                progress,
                weights,
                TableRepairWorkflowStep.Safety,
                1,
                0,
                target,
                _checkpoint.MoveSegmentStartUm);

            if (!await VerifySpindleAndTableAtTargetSpeedAtPhaseEndAsync(
                    progress,
                    "安全",
                    cancellationToken).ConfigureAwait(false))
            {
                return false;
            }

            return true;
        }

        private async Task<bool> ExecuteGrindPhaseAsync(
            ITableRepairWorkflowProgress progress,
            SelfGrindPhaseWeights weights,
            CancellationToken cancellationToken)
        {
            await EnsureCoolantOnAsync(cancellationToken).ConfigureAwait(false);

            double grindStartUm;
            double target;
            var speed = ResolveGrindSpeed(_checkpoint.Request.Config);
            var totalGrindAmount = _checkpoint.Request.GrindAmount;
            var isDebugGrind = IsDebugMode();
            var safetyEndBuffer = ResolveSafetyEndBuffer(_checkpoint.Request.Config);
            var calibrationB = _checkpoint.Request.B;
            var totalGrindTravel = isDebugGrind
                ? totalGrindAmount
                : safetyEndBuffer + totalGrindAmount;

            if (isDebugGrind)
            {
                grindStartUm = GetWheelPosition();
                _checkpoint.MoveSegmentStartUm = grindStartUm;
                target = grindStartUm + totalGrindAmount;
                TryApplyDebugMoveOverride(ref target, ref speed);
            }
            else
            {
                grindStartUm = _checkpoint.SafetyPosition;
                _checkpoint.MoveSegmentStartUm = grindStartUm;
                target = _checkpoint.GrindTargetPosition;
            }

            if (!await _wheelMove.TickMoveUntilAsync(
                target,
                speed,
                () => AwaitRunGateAsync(cancellationToken),
                ThrowIfTorqueAccident,
                async () =>
                {
                    await ThrowIfOverloadExceededAsync(progress, cancellationToken).ConfigureAwait(false);

                    var currentPosition = GetWheelPosition();
                    var traveled = Math.Abs(grindStartUm - currentPosition);
                    double processProgress;
                    if (isDebugGrind)
                    {
                        processProgress = totalGrindAmount > 0
                            ? Math.Min(100, traveled / totalGrindAmount * 100)
                            : 0;
                    }
                    else
                    {
                        var cutBelowB = Math.Max(0, currentPosition - calibrationB);
                        processProgress = totalGrindAmount > 0
                            ? Math.Min(100, cutBelowB / totalGrindAmount * 100)
                            : 0;
                    }

                    var phaseProgress = totalGrindTravel > 0
                        ? Math.Min(1, traveled / totalGrindTravel)
                        : 0;
                    ReportPhaseProgressForDebug(
                        progress,
                        weights,
                        TableRepairWorkflowStep.Grind,
                        phaseProgress,
                        processProgress,
                        target,
                        grindStartUm);
                },
                cancellationToken,
                TableRepairWheelMoveController.PositionToleranceUm,
                enableStallDetection: true,
                shouldAbortEarly: () => _fastForwardRequested).ConfigureAwait(false))
            {
                return false;
            }

            ReportPhaseProgressForDebug(
                progress,
                weights,
                TableRepairWorkflowStep.Grind,
                1,
                100,
                target,
                grindStartUm);
            return true;
        }

        private async Task<bool> ExecuteSparkOutPhaseAsync(
            ITableRepairWorkflowProgress progress,
            SelfGrindPhaseWeights weights,
            CancellationToken cancellationToken)
        {
            var totalSeconds = ResolveSparkOutSeconds(_checkpoint.Request.Config);
            if (IsDebugMode())
            {
                if (_debugSparkOutSecondsOverride > 0)
                {
                    totalSeconds = _debugSparkOutSecondsOverride;
                }

                ClearDebugOverrides();
            }

            Logs.LogInfo(
                $"[SelfGrind-Overload] SparkOut enter totalSeconds={totalSeconds:F1} pos={GetWheelPosition():F0}");

            if (totalSeconds <= 0)
            {
                Logs.LogInfo(
                    $"[SelfGrind-Overload] SparkOut done elapsed=0/{totalSeconds:F1} pos={GetWheelPosition():F0}");
                ReportPhaseProgressForDebug(
                    progress,
                    weights,
                    TableRepairWorkflowStep.SparkOut,
                    1,
                    100,
                    GetWheelPosition(),
                    GetWheelPosition());
                return true;
            }

            while (_checkpoint.SparkOutElapsedSeconds < totalSeconds)
            {
                if (_fastForwardRequested)
                {
                    _checkpoint.SparkOutElapsedSeconds = totalSeconds;
                    break;
                }

                await AwaitRunGateAsync(cancellationToken).ConfigureAwait(false);
                ThrowIfTorqueAccident();
                await ThrowIfOverloadExceededAsync(progress, cancellationToken).ConfigureAwait(false);

                var sliceStart = DateTime.UtcNow;
                await Task.Delay(100, cancellationToken).ConfigureAwait(false);
                _checkpoint.SparkOutElapsedSeconds += (DateTime.UtcNow - sliceStart).TotalSeconds;

                var elapsed = Math.Min(_checkpoint.SparkOutElapsedSeconds, totalSeconds);
                var phaseProgress = Math.Min(1, elapsed / totalSeconds);
                ReportPhaseProgressForDebug(
                    progress,
                    weights,
                    TableRepairWorkflowStep.SparkOut,
                    phaseProgress,
                    100,
                    GetWheelPosition(),
                    GetWheelPosition());
            }

            _checkpoint.SparkOutElapsedSeconds = totalSeconds;
            Logs.LogInfo(
                $"[SelfGrind-Overload] SparkOut done elapsed={totalSeconds:F1}/{totalSeconds:F1} pos={GetWheelPosition():F0}");
            ReportPhaseProgressForDebug(
                progress,
                weights,
                TableRepairWorkflowStep.SparkOut,
                1,
                100,
                GetWheelPosition(),
                GetWheelPosition());
            return true;
        }

        private async Task<bool> ExecuteEscapePhaseAsync(
            ITableRepairWorkflowProgress progress,
            SelfGrindPhaseWeights weights,
            CancellationToken cancellationToken)
        {
            var phaseStarted = DateTime.UtcNow;
            _wheelMove.Reset();

            var config = _checkpoint.Request.Config;
            var escapeSpeed = config.EscapeSpeed > 0 ? config.EscapeSpeed : 1;
            var escapeDistance = config.EscapeDistance > 0 ? config.EscapeDistance : 5;
            _checkpoint.MoveSegmentStartUm = GetWheelPosition();
            _checkpoint.EscapeTargetUm = _checkpoint.MoveSegmentStartUm - escapeDistance;

            var target = _checkpoint.EscapeTargetUm;
            TryApplyDebugMoveOverride(ref target, ref escapeSpeed);
            _checkpoint.EscapeTargetUm = target;
            _lastWheelPositionUm = GetWheelPosition();
            var startPos = _checkpoint.MoveSegmentStartUm;

            Logs.LogInfo(
                $"[SelfGrind-Overload] Escape enter startPos={startPos:F3} target={target:F3} speed={escapeSpeed:F3}um/s distance={escapeDistance:F3}um");

            if (!await _wheelMove.TickMoveUntilAsync(
                target,
                escapeSpeed,
                () => AwaitRunGateAsync(cancellationToken),
                ThrowIfTorqueAccident,
                async () =>
                {
                    await ThrowIfOverloadExceededAsync(progress, cancellationToken).ConfigureAwait(false);
                    var phaseProgress = CalculateMovePhaseProgress(
                        _checkpoint.MoveSegmentStartUm,
                        target,
                        GetWheelPosition());
                    ReportPhaseProgressForDebug(
                        progress,
                        weights,
                        TableRepairWorkflowStep.Escape,
                        phaseProgress,
                        0,
                        target,
                        _checkpoint.MoveSegmentStartUm);
                },
                cancellationToken,
                TableRepairWheelMoveController.PositionToleranceUm,
                enableStallDetection: true,
                shouldAbortEarly: () => _fastForwardRequested).ConfigureAwait(false))
            {
                return false;
            }

            var finalPos = GetWheelPosition();
            Logs.LogInfo(
                $"[SelfGrind-SpinStop] Escape done spindleTableStillRunning={_checkpoint.SpindleAndTableRunning} " +
                $"finalPos={finalPos:F3} next=WheelHome");
            Logs.LogInfo(
                $"[SelfGrind-Overload] Escape done finalPos={finalPos:F3} deltaUm={finalPos - startPos:F3} elapsedMs={(DateTime.UtcNow - phaseStarted).TotalMilliseconds:F0}");

            ReportPhaseProgressForDebug(
                progress,
                weights,
                TableRepairWorkflowStep.Escape,
                1,
                0,
                target,
                _checkpoint.MoveSegmentStartUm);
            return true;
        }

        private async Task<bool> ExecuteWheelHomePhaseAsync(
            ITableRepairWorkflowProgress progress,
            SelfGrindPhaseWeights weights,
            CancellationToken cancellationToken)
        {
            var phaseStarted = DateTime.UtcNow;

            await _controlCard.StopAxisAsync(AxisType.Wheel).ConfigureAwait(false);
            _wheelMove.Reset();

            _checkpoint.MoveSegmentStartUm = GetWheelPosition();
            _lastWheelPositionUm = _checkpoint.MoveSegmentStartUm;
            _wheelHomeMidpointStopped = false;
            var homingStartUm = _checkpoint.MoveSegmentStartUm;
            var midpointUm = homingStartUm / 2.0;
            var homeTolerance = TableRepairWheelMoveController.HomePositionToleranceUm;
            var homeConfig = _checkpoint.Request?.Config;
            _lastWheelHomeOverloadLogUtc = DateTime.MinValue;
            _lastSpinStopTickLogUtc = DateTime.MinValue;
            _lastSpinStopLoggedPos = double.NaN;
            Logs.LogInfo(
                $"[SelfGrind-SpinStop] WheelHome enter homingStartUm={homingStartUm:F0} midpointUm={midpointUm:F0} " +
                $"tolerance={homeTolerance:F0} spindleTableRunning={_checkpoint.SpindleAndTableRunning} path=NormalHoming50");
            Logs.LogInfo(
                $"[SelfGrind-Home] ExecuteWheelHomePhaseAsync enter step=WheelHome pos={_checkpoint.MoveSegmentStartUm:F3} stopRequested={_stopRequested} " +
                $"wheelLimit={homeConfig?.WheelOverloadLimit ?? 0:F1} tableLimit={homeConfig?.TableOverloadLimit ?? 0:F1} spindleRunning={_checkpoint.SpindleAndTableRunning}");

            if (!await _wheelMove.TickHomeUntilAsync(
                () => AwaitRunGateAsync(cancellationToken),
                ThrowIfTorqueAccident,
                async () =>
                {
                    MaybeLogWheelHomeOverloadTelemetry(homeConfig);
                    await ThrowIfOverloadExceededAsync(progress, cancellationToken).ConfigureAwait(false);
                    var currentPos = GetWheelPosition();
                    await TryStopSpindleAndTableAtHomingMidpointAsync(
                        homingStartUm,
                        currentPos,
                        ref _wheelHomeMidpointStopped,
                        "NormalHoming50").ConfigureAwait(false);
                    MaybeLogWheelHomeSpinStopTick(homingStartUm, currentPos, midpointUm);
                    var phaseProgress = homingStartUm != 0
                        ? Math.Min(1, Math.Abs(homingStartUm - currentPos) / Math.Abs(homingStartUm))
                        : 1;
                    ReportWeightedProgress(progress, weights, TableRepairWorkflowStep.WheelHome, phaseProgress, 100);
                },
                cancellationToken).ConfigureAwait(false))
            {
                Logs.LogError("[SelfGrind-Home] ExecuteWheelHomePhaseAsync failed: wheel homing did not complete.");
                return false;
            }

            await EnsureSpindleStoppedAfterReturnPhaseAsync(
                nameof(ExecuteWheelHomePhaseAsync),
                _wheelHomeMidpointStopped).ConfigureAwait(false);

            ReportWeightedProgress(progress, weights, TableRepairWorkflowStep.WheelHome, 1, 100);
            ScheduleCoolantOffAfterHomingAsync();

            var finalPos = GetWheelPosition();
            Logs.LogInfo(
                $"[SelfGrind-SpinStop] WheelHome exit midpointStopped={_wheelHomeMidpointStopped} " +
                $"spindleTableRunning={_checkpoint.SpindleAndTableRunning} finalPos={finalPos:F3}");
            Logs.LogInfo(
                $"[SelfGrind-Home] ExecuteWheelHomePhaseAsync exit step=WheelHome finalPos={finalPos:F3} elapsedMs={(DateTime.UtcNow - phaseStarted).TotalMilliseconds:F0}");
            return true;
        }

        private async Task AwaitRunGateAsync(CancellationToken cancellationToken)
        {
            var wasPaused = false;

            while (_pauseRequested && !_stopRequested)
            {
                if (!wasPaused)
                {
                    LogDebugInfo($"AwaitRunGate waiting step={_checkpoint?.Step}");
                }

                wasPaused = true;
                cancellationToken.ThrowIfCancellationRequested();
                await Task.Delay(100, cancellationToken).ConfigureAwait(false);
            }

            ThrowIfStopRequested();

            if (wasPaused)
            {
                LogDebugInfo($"AwaitRunGate resumed step={_checkpoint?.Step}");
            }

            if (wasPaused
                && ShouldResumeSpindleAndTable()
                && !_checkpoint.SpindleAndTableRunning)
            {
                if (!await StartSpindleAndTableAsync(_checkpoint.Request.Config, cancellationToken).ConfigureAwait(false))
                {
                    throw new InvalidOperationException("Failed to restart spindle and table after pause.");
                }

                _checkpoint.SpindleAndTableRunning = true;
            }
        }

        private async Task EnterPauseAsync()
        {
            LogDebugInfo($"EnterPauseAsync step={_checkpoint?.Step}");
            _wheelMove.Reset();

            try
            {
                await _controlCard.StopAxisAsync(AxisType.Table).ConfigureAwait(false);
                await _controlCard.StopAxisAsync(AxisType.Wheel).ConfigureAwait(false);
                await _inventerService.FreeStopAsync(false).ConfigureAwait(false);
                _checkpoint.SpindleAndTableRunning = false;
            }
            catch (Exception ex)
            {
                Logs.LogWarning($"Self-Grind pause motion warning: {ex.Message}");
            }

            IsPaused = true;
        }

        private async Task<bool> EnsureSpindleAndTableRunningAsync(
            CancellationToken cancellationToken,
            bool reportFailure = true)
        {
            if (_checkpoint.SpindleAndTableRunning)
            {
                return true;
            }

            if (!await StartSpindleAndTableAsync(_checkpoint.Request.Config, cancellationToken).ConfigureAwait(false))
            {
                if (reportFailure)
                {
                    var msg = "主轴/转台启动失败（频率未到位或驱动异常）。";
                    ReportWorkflowError(_workflowProgress, msg);
                }

                return false;
            }

            _checkpoint.SpindleAndTableRunning = true;
            return true;
        }

        private void ThrowIfStopRequested()
        {
            if (_stopRequested)
            {
                throw new OperationCanceledException("Self-Grind stop requested.");
            }
        }

        private async Task<TableRepairOutcome> HandleFailureAsync(ITableRepairWorkflowProgress progress)
        {
            var msg = _pendingWorkflowErrorMessage;
            if (string.IsNullOrWhiteSpace(msg))
            {
                msg = $"阶段执行失败（Step={_checkpoint?.Step}）。";
            }

            _pendingWorkflowErrorMessage = null;
            ReportWorkflowError(progress, msg);
            progress?.ReportPhase("失败");
            await StopMotionAndHomeAsync().ConfigureAwait(false);
            progress?.ReportEndPosition(GetWheelPosition());
            return TableRepairOutcome.Failed;
        }

        private static double CalculateMovePhaseProgress(
            double startPosition,
            double targetPosition,
            double currentPosition)
        {
            var totalDistance = Math.Abs(targetPosition - startPosition);
            if (totalDistance <= 0)
            {
                return 1;
            }

            var traveled = Math.Abs(currentPosition - startPosition);
            return Math.Min(1, traveled / totalDistance);
        }

        private void ReportWeightedProgress(
            ITableRepairWorkflowProgress progress,
            SelfGrindPhaseWeights weights,
            TableRepairWorkflowStep step,
            double phaseProgress01,
            double processProgress)
        {
            var total = weights.Total;
            if (total <= 0)
            {
                total = 100;
            }

            var currentWeight = weights.WeightFor(step);
            var overall = (_checkpoint.CompletedWeightRatio * total + currentWeight * phaseProgress01) / total * 100;
            progress?.ReportProgress(Math.Min(100, overall), processProgress);
        }

        private bool ValidatePreconditions(TableRepairRequest request, out string errorMessage)
        {
            errorMessage = null;

            if (!_controlCard.Initialized)
            {
                errorMessage = "控制卡未初始化，无法运动。";
                Logs.LogError($"[SelfGrind] ValidatePreconditions: {errorMessage}");
                return false;
            }

            if (IsDebugRequest(request))
            {
                LogDebugInfo("ValidatePreconditions skipped (Debug mode, control card OK)");
                return true;
            }

            if (ShouldEnforceRuntimeInterlocks()
                && !_inventerService.IsHandwareDemoPlatForm
                && !_controlCard.IsSafetyDoorFullyClosed)
            {
                errorMessage = "安全门未关闭。";
                Logs.LogError($"[SelfGrind] ValidatePreconditions: {errorMessage}");
                return false;
            }

            if (request.GrindAmount <= 0)
            {
                errorMessage = "研磨量无效。";
                Logs.LogError($"[SelfGrind] ValidatePreconditions: {errorMessage}");
                return false;
            }

            if (request.B >= request.A)
            {
                errorMessage = "B 必须小于 A（数值越大越远离主轴）。";
                Logs.LogError($"[SelfGrind] ValidatePreconditions: {errorMessage} A={request.A:F0} B={request.B:F0}");
                return false;
            }

            var buffer = ResolveSafetyEndBuffer(request.Config);
            var offset = ResolveRapidApproachOffset(request.Config);
            var rapidEnd = request.B - buffer - offset;
            var startC = GetWheelPosition();
            if (startC >= rapidEnd)
            {
                errorMessage =
                    "主轴位置须高于快进终点才能开始（当前 Z 须小于 B − SafetyEndBuffer − RapidApproachOffset）。";
                Logs.LogError(
                    $"[SelfGrind] ValidatePreconditions: {errorMessage} Z={startC:F0} rapidEnd={rapidEnd:F0} B={request.B:F0} buffer={buffer:F0} offset={offset:F0}");
                return false;
            }

            return true;
        }

        private async Task<bool> StartSpindleAndTableAsync(
            SelfGrindConfig config,
            CancellationToken cancellationToken,
            bool skipFrequencyWait = false)
        {
            LogSpindleTelemetry("start-before");
            await PrepareInventerPdoWriteWindowAsync(cancellationToken).ConfigureAwait(false);

            await TryWriteInventerParameterAsync(
                () => _inventerService.SetAcceTimeAsync(20),
                "AcceTime",
                20).ConfigureAwait(false);
            await TryWriteInventerParameterAsync(
                () => _inventerService.SetDeceTimeAsync(20),
                "DeceTime",
                20).ConfigureAwait(false);

            var wheelRpm = ResolveWheelRpm(config);
            await TryWriteInventerParameterAsync(
                () => _inventerService.SetRPMAsync(wheelRpm),
                "SetRPM",
                (uint)Math.Max(0, wheelRpm)).ConfigureAwait(false);
            await TryWriteInventerParameterAsync(
                () => _inventerService.RunForwardAsync(),
                "RunForward",
                0).ConfigureAwait(false);

            _controlCard.SetSpeed(AxisType.Table, ResolveTableRpm(config));
            await _controlCard.MoveContinueAsync(AxisType.Table, MoveDirection.正向, cancellationToken).ConfigureAwait(false);

            if (!skipFrequencyWait && IsDebugMode() && !_inventerService.FrequencyReached)
            {
                LogDebugInfo("Debug mode: spindle frequency not reached, continuing without wait");
            }

            LogSpindleTelemetry("start-after");
            return true;
        }

        private async Task PrepareInventerPdoWriteWindowAsync(CancellationToken cancellationToken)
        {
            if (_inventerService.IsHandwareDemoPlatForm || !_controlCard.Initialized)
            {
                return;
            }

            await Task.Delay(SpindlePdoSettleDelayMs, cancellationToken).ConfigureAwait(false);

            if (!IsWheelAxisBusyForPdo())
            {
                return;
            }

            Logs.LogInfo("[SelfGrind] Wheel motion active before spindle PDO write; waiting for quiet window.");
            var elapsed = 0;
            while (elapsed < SpindlePdoWheelQuietTimeoutMs && IsWheelAxisBusyForPdo())
            {
                cancellationToken.ThrowIfCancellationRequested();
                await Task.Delay(SpindlePdoWheelQuietPollMs, cancellationToken).ConfigureAwait(false);
                elapsed += SpindlePdoWheelQuietPollMs;
            }

            if (IsWheelAxisBusyForPdo())
            {
                Logs.LogWarning(
                    $"[SelfGrind] Wheel still active after {SpindlePdoWheelQuietTimeoutMs}ms; " +
                    "using extended PDO write retries during motion.");
            }
            else
            {
                Logs.LogInfo($"[SelfGrind] PDO quiet window ready after {elapsed}ms wait.");
            }
        }

        private bool IsWheelAxisBusyForPdo()
        {
            var wheelIndex = (int)AxisType.Wheel;
            if (_controlCard.ServoDatas == null || _controlCard.ServoDatas.Count <= wheelIndex)
            {
                return false;
            }

            var wheel = _controlCard.ServoDatas[wheelIndex];
            return wheel.IsMoving || Math.Abs(wheel.ActualVelocity) > SpindlePdoWheelQuietVelocityThreshold;
        }

        private (int maxAttempts, int retryDelayMs) GetInventerWriteRetryPolicy()
        {
            if (IsWheelAxisBusyForPdo())
            {
                return (SpindleParameterWriteMaxAttemptsDuringMotion, SpindleParameterWriteRetryDelayDuringMotionMs);
            }

            return (SpindleParameterWriteMaxAttempts, SpindleParameterWriteRetryDelayMs);
        }

        private async Task<bool> TryWriteInventerParameterAsync(
            Func<Task<bool>> writeAsync,
            string parameterName,
            uint attemptedValue)
        {
            var (maxAttempts, retryDelayMs) = GetInventerWriteRetryPolicy();
            for (var attempt = 1; attempt <= maxAttempts; attempt++)
            {
                if (await writeAsync().ConfigureAwait(false))
                {
                    if (attempt > 1)
                    {
                        Logs.LogInfo(
                            $"[SelfGrind] Spindle {parameterName} write succeeded on attempt {attempt}/{maxAttempts}.");
                    }

                    return true;
                }

                Logs.LogWarning(
                    $"[SelfGrind] Spindle {parameterName} write failed attempt {attempt}/{maxAttempts} value={attemptedValue}.");
                if (attempt < maxAttempts)
                {
                    await Task.Delay(retryDelayMs * attempt).ConfigureAwait(false);
                }
            }

            Logs.LogWarning(
                $"[SelfGrind] Spindle {parameterName} write failed after {maxAttempts} attempts; continuing startup.");
            return false;
        }

